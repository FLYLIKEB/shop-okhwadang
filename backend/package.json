{
  "name": "shop-okhwadang-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:coverage": "jest --coverage",
    "test:e2e:app": "DATABASE_URL=${TEST_DATABASE_URL:-$DATABASE_URL} node ./test/reset-test-db.js && DATABASE_URL=${TEST_DATABASE_URL:-$DATABASE_URL} npm run migration:run && jest --runInBand --config ./test/jest-e2e.json test/app.e2e-spec.ts",
    "test:e2e:auth-password-reset": "TEST_DATABASE_URL=${TEST_DATABASE_URL:-$DATABASE_URL} DATABASE_URL=${TEST_DATABASE_URL:-$DATABASE_URL} jest --runInBand --config ./test/jest-e2e.json test/auth-password-reset.e2e-spec.ts",
    "test:e2e": "npm run test:e2e:app && npm run test:e2e:auth-password-reset",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/typeorm.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/typeorm.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/typeorm.config.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/typeorm.config.ts",
    "migration:run:prod": "typeorm migration:run -d dist/database/typeorm.config.js",
    "migration:revert:prod": "typeorm migration:revert -d dist/database/typeorm.config.js",
    "migration:show:prod": "typeorm migration:show -d dist/database/typeorm.config.js",
    "seed": "ts-node src/database/seeds/run-seed.ts",
    "seed:prod": "node dist/database/seeds/run-seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/node": "^10.49.0",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "csv-stringify": "^6.7.0",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "stripe": "^21.0.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.58.2"
  },
  "overrides": {
    "path-to-regexp": "^8.4.1",
    "picomatch": "^4.0.4",
    "file-type": "^21.3.4",
    "follow-redirects": "^1.16.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/*.dto.ts",
      "!**/*.entity.ts",
      "!**/migrations/**",
      "!**/__mocks__/**"
    ],
    "coverageReporters": [
      "text",
      "html",
      "lcov",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 75,
        "branches": 65,
        "functions": 75,
        "lines": 75
      }
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
