NODE_ENV=development
PORT=3000

# For production: use AWS Secrets Manager (see infra/secrets/SECRETS_MANAGER_SETUP.md)
# MYSQL_PASSWORD, JWT_SECRET, JWT_REFRESH_SECRET, TOSS_SECRET_KEY,
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, REDIS_PASSWORD, AWS_SECRET_ACCESS_KEY
MYSQL_ROOT_PASSWORD=changeme_root_password
REDIS_PASSWORD=changeme_redis_password
LOCAL_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@127.0.0.1:3307/okhwadang
TEST_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@127.0.0.1:3307/okhwadang_test
DB_SYNCHRONIZE=false
DB_SSL_ENABLED=false

# ─────────────────────────────────────────────
# 원격 DB 접속 (Railway MySQL)
# ─────────────────────────────────────────────
# Railway 프록시 사용 시 (로컬에서 직접 접속)
MYSQL_HOST=yamabiko.proxy.rlwy.net
MYSQL_PORT=27950
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=railway

# ─────────────────────────────────────────────
# 원격 DB 접속 (AWS Lightsail SSH 터널)
# ─────────────────────────────────────────────
# SSH 터널을 통해 원격 MySQL에 접속할 때 사용
# 터널 스크립트: backend/scripts/start-ssh-tunnel.sh
SSH_TUNNEL_ENABLED=false
SSH_TUNNEL_LOCAL_PORT=3307
SSH_TUNNEL_REMOTE_HOST=   # EC2 public IP
SSH_TUNNEL_REMOTE_PORT=3306
SSH_KEY_PATH=~/.ssh/your-key.pem

# 원격 DB 직접 접속 (터널 사용 시에는 LOCAL_DATABASE_URL 사용)
# DATABASE_URL=mysql://user:password@<lightsail-private-ip>:3306/okhwadang

# ─────────────────────────────────────────────
# JWT (REQUIRED in production)
# ─────────────────────────────────────────────
JWT_SECRET=  # generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=  # must differ from JWT_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6380

# ─────────────────────────────────────────────
# ElastiCache Redis (AWS 프로덕션)
# ─────────────────────────────────────────────
# REDIS_URL=redis://:<REDIS_PASSWORD>@<your-elasticache-endpoint>:6379
# 예: REDIS_URL=redis://:MyAuthToken@okhwadang-redis.xxxxxx.aps2.cache.amazonaws.com:6379
PAYMENT_GATEWAY=mock  # Required in production. 'mock' is blocked in production. Options: mock, toss, stripe
TOSS_SECRET_KEY=   # Toss Payments secret key (for ko locale)
TOSS_CLIENT_KEY=   # Toss Payments client key (for ko locale)
STRIPE_SECRET_KEY=   # Stripe secret key (for global locale)
STRIPE_WEBHOOK_SECRET=   # Stripe webhook signing secret
STORAGE_PROVIDER=local  # s3 or local
AWS_S3_BUCKET=okhwadang-assets
AWS_CLOUDFRONT_DOMAIN=xxxxxxxx.cloudfront.net
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CDN_URL=
KAKAO_CLIENT_ID=   # kakao app client id
KAKAO_CLIENT_SECRET=   # kakao app client secret
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
GOOGLE_CLIENT_ID=   # google oauth client id
GOOGLE_CLIENT_SECRET=   # google oauth client secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
