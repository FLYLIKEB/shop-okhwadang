NODE_ENV=development
PORT=3000
MYSQL_ROOT_PASSWORD=__REDACTED_ROOT_PW__
REDIS_PASSWORD=__REDACTED_REDIS_PW__
LOCAL_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@127.0.0.1:3307/okhwadang
TEST_DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@127.0.0.1:3307/okhwadang_test
DB_SYNCHRONIZE=false
DB_SSL_ENABLED=false
JWT_SECRET=  # REQUIRED: generate with: openssl rand -hex 32. Rotate immediately if leaked.
JWT_REFRESH_SECRET=  # REQUIRED in production: must differ from JWT_SECRET. generate with: openssl rand -hex 32
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6380
PAYMENT_GATEWAY=mock  # Required in production. 'mock' is blocked in production. Options: mock, toss, stripe
TOSS_SECRET_KEY=   # Toss Payments secret key (for ko locale)
TOSS_CLIENT_KEY=   # Toss Payments client key (for ko locale)
STRIPE_SECRET_KEY=   # Stripe secret key (for global locale)
STRIPE_WEBHOOK_SECRET=   # Stripe webhook signing secret
STORAGE_PROVIDER=local
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CDN_URL=
KAKAO_CLIENT_ID=   # kakao app client id
KAKAO_CLIENT_SECRET=   # kakao app client secret
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
GOOGLE_CLIENT_ID=   # google oauth client id
GOOGLE_CLIENT_SECRET=   # google oauth client secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
